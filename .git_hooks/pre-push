#!/bin/sh
# FOSM Phoenix pre-push hook
# Runs comprehensive checks including tests and Dialyzer

echo "🔍 Running pre-push checks..."

# Store the exit status
EXIT_STATUS=0

# Check formatting
echo "📐 Checking formatting..."
mix format --check-formatted
if [ $? -ne 0 ]; then
    echo "❌ Formatting issues found. Run 'mix format' to fix."
    EXIT_STATUS=1
fi

# Run Credo in strict mode
echo "🔎 Running Credo (strict mode)..."
mix credo --strict
if [ $? -ne 0 ]; then
    echo "❌ Credo found issues."
    EXIT_STATUS=1
fi

# Check for compiler warnings
echo "🔨 Checking for compiler warnings..."
mix compile --warnings-as-errors
if [ $? -ne 0 ]; then
    echo "❌ Compiler warnings found."
    EXIT_STATUS=1
fi

# Run tests
echo "🧪 Running tests..."
mix test
if [ $? -ne 0 ]; then
    echo "❌ Tests failed."
    EXIT_STATUS=1
fi

# Run Dialyzer (this can be slow, so it's only on pre-push)
echo "🔬 Running Dialyzer..."
mix dialyzer
if [ $? -ne 0 ]; then
    echo "❌ Dialyzer found type issues."
    EXIT_STATUS=1
fi

if [ $EXIT_STATUS -eq 0 ]; then
    echo "✅ All pre-push checks passed! Ready to push."
else
    echo "🚫 Pre-push checks failed. Please fix the issues above."
fi

exit $EXIT_STATUS
